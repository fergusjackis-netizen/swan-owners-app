rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isApproved() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin();
      allow delete: if isAdmin();
    }

    match /yachts/{yachtId} {
      allow read: if true;
      allow create, update: if isApproved() && request.auth.uid == yachtId;
      allow delete: if isAdmin();
    }

    match /locations/{uid} {
      allow read: if isApproved();
      allow write: if isApproved() && request.auth.uid == uid;
    }

    match /issues/{issueId} {
      allow read: if true;
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isAdmin();
      match /replies/{replyId} {
        allow read: if true;
        allow create: if isApproved();
        allow delete: if isAdmin();
      }
    }

    match /forum/{topicId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isAdmin();
      match /replies/{replyId} {
        allow read: if isApproved();
        allow create: if isApproved();
        allow delete: if isAdmin();
      }
    }

    match /contacts/{contactId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if isAdmin();
    }

    match /messages/{threadId} {
      allow read, write: if isApproved();
      match /msgs/{msgId} {
        allow read, create: if isApproved();
      }
    }

    match /modelProposals/{proposalId} {
      allow read: if isAdmin();
      allow create: if isApproved();
      allow update, delete: if isAdmin();
    }

    match /models/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}